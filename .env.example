# ─────────────────────────────────────────────────────────────
# Arthur Herron Butchery — environment variables
# Copy this file to `.env` and fill in real values.
# (On Replit these are provided automatically as Secrets.)
# ─────────────────────────────────────────────────────────────

# ── Database (required) ───────────────────────────────────────
# PostgreSQL connection string used by the API server + drizzle.
DATABASE_URL=postgresql://user:password@localhost:5432/arthur_herron

# ── Authentication: Clerk (required) ──────────────────────────
# Create a free app at https://dashboard.clerk.com and copy its keys.
# Backend (API server):
CLERK_PUBLISHABLE_KEY=<your-clerk-publishable-key>
CLERK_SECRET_KEY=<your-clerk-secret-key>
# Frontend (Vite / web app) — must be the SAME publishable key:
VITE_CLERK_PUBLISHABLE_KEY=<your-clerk-publishable-key>
# Leave EMPTY off Replit (only used by the Replit-managed Clerk proxy):
VITE_CLERK_PROXY_URL=

# ── Admin dashboard (required) ────────────────────────────────
# Password used to log into /admin.
ADMIN_PASSWORD=change-me

# ── Payments: Pesepay (required for checkout) ─────────────────
# Get these from your Pesepay merchant account.
PESEPAY_INTEGRATION_KEY=your-integration-key
PESEPAY_ENCRYPTION_KEY=your-encryption-key
# "production" for live payments, anything else = test mode.
PESEPAY_MODE=test

# ── Server config ─────────────────────────────────────────────
# Port the API server listens on (Replit injects this automatically).
PORT=8080
NODE_ENV=development
# Optional: pino log level (info, debug, warn, error).
LOG_LEVEL=info
# Optional: base path prefix for the API (leave unset to serve at root).
BASE_PATH=

# ── Object storage (Replit-specific — see README) ─────────────
# These power product-image uploads via Replit App Storage.
# Off Replit you must replace src/lib/objectStorage.ts with your own
# provider (e.g. AWS S3, Cloudflare R2). See README "Replit-specific parts".
PRIVATE_OBJECT_DIR=
PUBLIC_OBJECT_SEARCH_PATHS=
